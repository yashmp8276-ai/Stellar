# Stellar Live Poll Configuration
# Copy this file to .env or .env.local to customize configuration in development.

# Soroban Smart Contract ID (leave empty or as-is to use Simulation Mode)
VITE_CONTRACT_ID=

# Soroban RPC server URL
VITE_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Stellar network passphrase for signature validation
VITE_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
